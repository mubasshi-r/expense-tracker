{
  "name": "expense-tracker-backend",
  "version": "1.0.0",
  "description": "Expense Tracker API - Node.js + Express + SQLite",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --passWithNoTests",
    "test:watch": "jest --watch",
    "migrate": "node src/db/migrate.js"
  },
  "keywords": ["expense", "tracker", "api"],
  "author": "mubasshi-r",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^9.2.2",
    "uuid": "^9.0.1",
    "decimal.js": "^10.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "node-mocks-http": "^1.13.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
